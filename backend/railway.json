{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install"
  },
  "deploy": {
    "startCommand": "npx prisma generate && npx prisma migrate deploy && node src/server.js",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30
  }
}
