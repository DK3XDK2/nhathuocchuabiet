# Sao chép file này thành .env và điền thông tin thực tế
# cp .env.example .env

# ========================
# Cơ sở dữ liệu MySQL
# ========================
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/TEN_DATABASE"
# Ví dụ: DATABASE_URL="mysql://root:123456@localhost:3306/qly_thuoc"

# ========================
# JWT Secret Key (đặt chuỗi ngẫu nhiên dài, khó đoán)
# ========================
KHOA_BI_MAT_JWT="thay-bang-chuoi-bi-mat-cua-ban-o-day"

# ========================
# Cổng server (mặc định 4000)
# ========================
CONG_SERVER=4000
